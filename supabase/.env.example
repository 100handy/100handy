# Supabase Edge Functions secrets.
# Copy to `supabase/.env` for local `supabase functions serve`, and set the same
# values in production with `supabase secrets set KEY=value`.
# (`supabase/.env` is gitignored; this .example is the committed template.)

# ─────────────────────────────────────────────────────────────────────────────
# NEW — Outreach discovery engine (Apify)
# Used by: outreach-discovery-trigger, outreach-discovery-webhook, outreach-discovery-cron
# ─────────────────────────────────────────────────────────────────────────────

# Apify API token — starts actor (scraper) runs and reads their datasets.
# Get it from Apify Console → Settings → Integrations → API token.
APIFY_TOKEN=

# Random secret used to HMAC-sign the Apify completion webhook URL so only Apify
# can post scraped results back. Generate: `openssl rand -hex 32`
APIFY_WEBHOOK_SECRET=

# Random secret the pg_cron dispatcher sends as the `x-cron-secret` header when it
# calls outreach-discovery-cron. Generate: `openssl rand -hex 32`
# NOTE: must equal the DB setting `app.settings.outreach_cron_secret` (see below).
OUTREACH_CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Existing — reused by the outreach features (set already in most envs)
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — classifies/draft outreach messages. Without it, a deterministic
# fallback draft is used (no AI). Used by run-outreach-agent, generate-outreach-draft,
# and the discovery webhook.
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
OUTREACH_AI_MODEL=gpt-4o-mini

# SMTP — sends approved outreach emails (worker leads with a public email) and the
# existing admin email campaigns. From address is `100 Handy <SMTP_USER>`.
# Used by send-outreach-message and send-admin-email-campaign.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# Auto-provided by the Supabase platform (no need to set in production secrets;
# only needed in supabase/.env for fully local function runs).
# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Database settings for scheduled discovery (set via SQL, NOT here):
#   alter database postgres set app.settings.functions_base_url   = 'https://<ref>.supabase.co';
#   alter database postgres set app.settings.outreach_cron_secret = '<same as OUTREACH_CRON_SECRET>';
# Then (re-)run the cron.schedule(...) block in migration 20260614000021.
# ─────────────────────────────────────────────────────────────────────────────
