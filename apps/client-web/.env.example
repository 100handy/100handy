BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
DATABASE_URL=

# Site URL for email redirects (production only)
# For development, localhost will be used automatically
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Google Maps API Key (required for location autocomplete)
