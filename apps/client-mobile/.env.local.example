# Copy this file to .env.local and fill in your actual values

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Site URL for email redirects and auth callbacks in production (replace with your actual domain)
# For development, the system will automatically use localhost or handy:// scheme
# This URL is used for:
# - Email confirmation redirects
# - OAuth callback handling
# - Magic link authentication
EXPO_PUBLIC_SITE_URL=https://yourdomain.com

# Auth callback configuration
# The callback API route will handle email confirmations and redirects
# Make sure your Supabase project is configured with the correct callback URL:
# https://yourdomain.com/auth/callback (for production)
# handy://auth/callback (for mobile deep linking)

# Edge Functions URL (for calling your custom functions)
# Local development: http://127.0.0.1:54321/functions/v1
# Production: https://your-project-ref.supabase.co/functions/v1
EXPO_PUBLIC_SUPABASE_FUNCTIONS_URL=https://your-project-ref.supabase.co/functions/v1

